# pai-mobile — Safe Defaults for Subscription-Backed Agents
#
# Copy to .env and fill in your values.
# The .env file should NEVER be committed to git.

# ─── Identity ────────────────────────────────────────────────
BOT_NAME=Raj
USER_NAME=YourName

# ─── Telegram ────────────────────────────────────────────────
# Get from @BotFather after /newbot
TELEGRAM_BOT_TOKEN=PASTE_FROM_BOTFATHER

# Get from @userinfobot after /start (just a number)
TELEGRAM_CHAT_ID=PASTE_FROM_USERINFOBOT

# ─── Timezone ────────────────────────────────────────────────
TIMEZONE=America/Los_Angeles

# ─── Claude ──────────────────────────────────────────────────
# Sonnet is plenty for chief-of-staff work. Don't default to Opus —
# it burns through your Max 5-hour rolling window way faster.
FULL_MODEL=sonnet
LITE_MODEL=haiku

# ─── Permission Mode ─────────────────────────────────────────
# Options:
#   default          — Claude asks for confirmation on risky actions
#                      ⚠️ NOTE: default mode breaks in pai-mobile (no terminal
#                      to prompt in). Use acceptEdits or bypassPermissions.
#   acceptEdits      — Auto-approve file edits, prompt for shell commands
#                      ✅ RECOMMENDED
#   bypassPermissions — No confirmations at all
#                      ⚠️ Only if you understand the security model (tight
#                      chat-ID allowlist + SOUL.md-level guardrails)
PERMISSION_MODE=acceptEdits

# ─── Rate Limits ─────────────────────────────────────────────
# Conservative caps so pai-mobile doesn't eat your Max rate limit
MAX_MESSAGES_PER_MINUTE=10
MAX_CONCURRENT_CLAUDE=2

# ─── Heartbeat ───────────────────────────────────────────────
# Disabled by default. To enable, see Kit's setup guide.
